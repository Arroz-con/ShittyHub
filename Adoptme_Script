                if not body or body.ok ~= true then
                    task.wait(2)
                    post(ackUrl, {
                        ['username'] = localPlayer.Name,
                        ['items'] = items,
                    })
                end
            end
            local inActiveTrade = function()
                return ClientData.get_data()[localPlayer.Name].in_active_trade == true
            end
            local senderOfferCount = function()
                local trade = ClientData.get_data()[localPlayer.Name].trade

                if trade and trade.sender_offer and trade.sender_offer.items then
                    return #trade.sender_offer.items
                end

                return 0
            end
            local waitForActiveTrade = function(timeOut)
                while not inActiveTrade() do
                    task.wait(1)

                    timeOut = timeOut - 1

                    if timeOut <= 0 then
                        return false
                    end
                end

                return true
            end
            local matchesWireItem = function(item, wanted)
                local props = item.properties or {}

                return item.id == wanted.id and (props.age or 0) == (wanted.age or 0) and (props.neon == true) == (wanted.neon == true) and (props.mega_neon == true) == (wanted.mega_neon == true)
            end
            local pickOffer = function(wireItems)
                local inventory = ClientData.get_data()[localPlayer.Name].inventory
                local offer = {}

                for _, wanted in wireItems do
                    if #offer >= MAX_PER_TRADE then
                        break
                    end
                    if table.find(AllowOrDenyList.Denylist, wanted.id) then
                        continue
                    end
                    if getgenv().SETTINGS.PETS_TO_AGE_IN_PEN[wanted.id] ~= nil then
                        continue
                    end

                    local page = inventory[wanted.category or 'pets']

                    if not page then
                        continue
                    end

                    local remaining = wanted.count or 0

                    for _, item in page do
                        if remaining <= 0 or #offer >= MAX_PER_TRADE then
                            break
                        end
                        if matchesWireItem(item, wanted) then
                            table.insert(offer, {
                                unique = item.unique,
                                id = wanted.id,
                                age = wanted.age or 0,
                                neon = wanted.neon == true,
                                mega_neon = wanted.mega_neon == true,
                                category = wanted.category or 'pets',
                            })

                            remaining = remaining - 1
                        end
                    end
                end

                return offer
            end
            local requestTradeWith = function(muleName)
                if inActiveTrade() then
                    return true
                end

                local mulePlayer = Players:FindFirstChild(muleName)

                if not mulePlayer then
                    return false
                end

                RouterClient.get('TradeAPI/SendTradeRequest'):FireServer(mulePlayer)

                return waitForActiveTrade(30)
            end
            local addOfferToTrade = function(offer)
                local addRemote = RouterClient.get('TradeAPI/AddItemToOffer')
                local added = {}

                for _, entry in offer do
                    if not inActiveTrade() then
                        break
                    end

                    local before = senderOfferCount()

                    if before >= MAX_PER_TRADE then
                        break
                    end

                    addRemote:FireServer(entry.unique)

                    local waited = 0

                    repeat
                        task.wait(0.1)

                        waited = waited + 0.1
                    until not inActiveTrade() or senderOfferCount() > before or waited >= 5

                    if inActiveTrade() and senderOfferCount() > before then
                        table.insert(added, entry)
                    end
                end

                return added
            end
            local muleCharacterReady = function(muleName)
                local mulePlayer = (Players:FindFirstChild(muleName))
                local character = mulePlayer and mulePlayer.Character

                return (character and character:FindFirstChild('HumanoidRootPart')) ~= nil
            end
            local stillOwned = function(category, unique)
                local page = ClientData.get_data()[localPlayer.Name].inventory[category]

                if not page then
                    return false
                end

                for _, item in page do
                    if item.unique == unique then
                        return true
                    end
                end

                return false
            end
            local tradeOnce = function(muleName, offer)
                if not requestTradeWith(muleName) then
                    return
                end

                local added = addOfferToTrade(offer)

                if #added == 0 then
                    if inActiveTrade() then
                        RouterClient.get('TradeAPI/DeclineTrade'):FireServer()
                    end

                    return
                end

                Trade.AcceptNegotiationAndConfirm()
                task.wait(2)

                local counts = {}

                for _, entry in added do
                    if stillOwned(entry.category, entry.unique) then
                        continue
                    end

                    local key = string.format('%s|%s|%s|%s', tostring(entry.id), tostring(entry.age), tostring(entry.neon), tostring(entry.mega_neon))

                    if counts[key] then
                        do
                            local __DARKLUA_VAR = counts[key]

                            __DARKLUA_VAR.count = __DARKLUA_VAR.count + 1
                        end
                    else
                        counts[key] = {
                            ['id'] = entry.id,
                            ['age'] = entry.age,
                            ['neon'] = entry.neon,
                            ['mega_neon'] = entry.mega_neon,
                            ['count'] = 1,
                        }
                    end
                end

                local ackItems = {}

                for _, item in counts do
                    table.insert(ackItems, item)
                end

                if #ackItems > 0 then
                    ackTrade(ackItems)
                    Utils.PrintDebug(string.format('\u{1f69a} gifted + acked %s item(s) to %s', tostring(#added), tostring(muleName)))
                end
            end
            local runVisit = function(visit)
                localPlayer:SetAttribute('StopFarmingTemp', true)
                Utils.PrintDebug(string.format('\u{1f69a} COLLECT VISIT started, mule: %s', tostring(visit.mule)))

                while visit do
                    if not muleCharacterReady(visit.mule) then
                        Utils.PrintDebug("\u{1f69a} waiting for the mule's character...")
                        task.wait(RETRY_WAIT)
                    else
                        local offer = pickOffer(visit.items or {})

                        if #offer == 0 then
                            Utils.PrintDebug('\u{1f69a} nothing tradeable from the wanted list')
                            task.wait(POLL_INTERVAL)
                        else
                            tradeOnce(visit.mule, offer)
                            task.wait(2)
                        end
                    end

                    visit = fetchVisit()
                end

                Utils.PrintDebug('\u{1f69a} COLLECT VISIT over')
                localPlayer:SetAttribute('StopFarmingTemp', false)
            end
            local checkForVisit = function()
                if busy then
                    return
                end

                busy = true

                local ok, err = pcall(function()
                    local visit = fetchVisit()

                    if visit then
                        print('visit:', visit)
                        runVisit(visit)
                    end
                end)

                if not ok then
                    warn('[CollectVisit] visit loop error:', err)
                    localPlayer:SetAttribute('StopFarmingTemp', false)
                end

                busy = false
            end

            function CollectVisitHandler.Init() end
            function CollectVisitHandler.Start()
                local key = getgenv().API_KEY

                if not key or #key < 30 then
                    warn('[CollectVisit] missing/short API key \u{2014} collect disabled')

                    return
                end
                if getgenv().SETTINGS.IS_MULE == true then
                    return
                end

                trove:Connect(Players.PlayerAdded, function(player)
                    print('player:', player)

                    local character = player.Character or player.CharacterAdded:Wait()

                    character:WaitForChild('HumanoidRootPart', 120)
                    task.wait(RETRY_WAIT)
                    checkForVisit()
                end)
                task.spawn(function()
                    task.wait(RETRY_WAIT)
                    checkForVisit()
                end)
            end

            return CollectVisitHandler
        end

        function __DARKLUA_BUNDLE_MODULES.I()
            local v = __DARKLUA_BUNDLE_MODULES.cache.I

            if not v then
                v = {
                    c = __modImpl(),
                }
                __DARKLUA_BUNDLE_MODULES.cache.I = v
            end

            return v.c
        end
    end
end

