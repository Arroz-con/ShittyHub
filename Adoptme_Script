        function Utils.InvokeServerWithTimeout(timeout, remoteFunction, ...)
            local result = nil
            local hasResponded = false
            local currentThread = coroutine.running()

            task.spawn(function(...)
                local success, response = pcall(remoteFunction.InvokeServer, remoteFunction, 
...)

                if not hasResponded then
                    hasResponded = true
                    result = {
                        success = success,
                        response = response,
                    }

                    task.spawn(currentThread)
                end
            end, ...)
            task.delay(timeout, function()
                if not hasResponded then
                    hasResponded = true

                    task.spawn(currentThread)
                end
            end)
            coroutine.yield()

            if result then
                return result.success, result.response
            else
                return false, 'Timed out waiting for server response'
            end
        end

        return Utils
    end
