            for catagory, v in InventoryDB do
                Utils.PrintDebug(string.format('Checking catagory: (%s) for item: %s', tostring(catagory), tostring(nameId)))

                for key, value in v do
                    if key == nameId then
                        return value
                    end
                end
            end

            return nil
        end
