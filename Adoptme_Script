    function __DARKLUA_BUNDLE_MODULES.w()
        local ReplicatedStorage = game:GetService('ReplicatedStorage')
        local Players = game:GetService('Players')
        local Bypass = (require(ReplicatedStorage:WaitForChild('Fsys')).load)
        local ClientData = Bypass('ClientData')
        local RouterClient = Bypass('RouterClient')
        local Utils = __DARKLUA_BUNDLE_MODULES.load('b')
        local PayBucks = {}
        local localPlayer = Players.LocalPlayer
        local rng = Random.new()
        local processedPlayers = {}
        local buyFurniture = function(furnitureId)
            local args = {
                {
                    {
                        ['kind'] = furnitureId,
                        ['properties'] = {
                            ['cframe'] = CFrame.new(14, 2, -22) * CFrame.Angles(-0, 8.7, 3.8),
                        },
                    },
                },
            }
            local response = RouterClient.get('HousingAPI/BuyFurnitures'):InvokeServer(unpack(args))

            if not response.success then
                return nil
            end

            return response.results[1].unique
        end
        local payUser = function(player, furnitureKey)
            if not (player or furnitureKey) then
                return
            end

            RouterClient.get('HousingAPI/ActivateFurniture'):InvokeServer(player, furnitureKey, 'UseBlock', 50, localPlayer.Character)
        end
        local getPlayerRegisterKey = function(player)
            RouterClient.get('HousingAPI/SubscribeToHouse'):FireServer(player)
            task.wait(5)

            local houseInterior = ClientData.get_data()[localPlayer.Name].house_interior

            if houseInterior then
                for key, value in houseInterior.furniture do
                    if value.id == 'cashregister' or value.id == 'golden_cash_register' then
                        return key
                    end
                end
            end

            return nil
        end
        local waitForPlayerRegister = function(player)
            while true do
                local key = getPlayerRegisterKey(player)

                if key then
                    return key
                end

                print('Waiting for player:', player.Name, 'to setup their register', DateTime.now():FormatLocalTime('LTS', 'en-us'))
                task.wait(60)
            end
        end
        local onPlayerAdded = function(player)
            if processedPlayers[player.Name] then
                return
            end

            processedPlayers[player.Name] = true

            if table.find(getgenv().SETTINGS.PAY_BUCKS_TO, localPlayer.Name) then
                return
            end
            if not table.find(getgenv().SETTINGS.PAY_BUCKS_TO, player.Name) then
                return
            end

            task.wait(rng:NextNumber(1, 10))

            local registerKey = waitForPlayerRegister(player)

            if not registerKey then
                print('Failed to find register for player:', player.Name)

                return
            end

            print('Found register for player:', player.Name, 'with key:', registerKey)
            print('Starting to pay')

            while Players:FindFirstChild(player.Name) do
                if Utils.BucksAmount() < 500 then
                    break
                end

                payUser(player, registerKey)
                print('Waiting 2mins for cooldown', DateTime.now():FormatLocalTime('LTS', 'en-us'))
                task.wait(120)
            end

            print('Finished paying for player:', player.Name)
        end
        local onPlayerRemoving = function(player)
            processedPlayers[player.Name] = nil
        end
        local trySetupRegister = function()
            local houseInterior = ClientData.get_data()[localPlayer.Name].house_interior

            if houseInterior then
                for key, value in houseInterior.furniture do
                    if value.id == 'cashregister' or value.id == 'golden_cash_register' then
                        return key
                    end
                end
            end

            return buyFurniture('cashregister')
        end

        function PayBucks.Init()
            task.spawn(function()
                if not getgenv().SETTINGS.PAY_BUCKS_TO then
                    return
                end
                if table.find(getgenv().SETTINGS.PAY_BUCKS_TO, localPlayer.Name) then
                    trySetupRegister()
                end

                Players.PlayerAdded:Connect(onPlayerAdded)
                Players.PlayerRemoving:Connect(onPlayerRemoving)
            end)
        end
        function PayBucks.Start()
            task.spawn(function()
                if not getgenv().SETTINGS.PAY_BUCKS_TO then
                    return
                end
                if table.find(getgenv().SETTINGS.PAY_BUCKS_TO, localPlayer.Name) then
                    trySetupRegister()
                end

                for _, player in Players:GetPlayers()do
                    onPlayerAdded(player)
                end
            end)
        end

        return PayBucks
    end
